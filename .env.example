# ─── Doda Backend — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-long-random-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── MongoDB Atlas ───────────────────────────────────────────────────────────────
# Get from: mongodb.com/atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://doda_api:YOUR-PASSWORD@cluster0.xxxxx.mongodb.net/doda?retryWrites=true&w=majority

# ── Cloudinary ─────────────────────────────────────────────────────────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=doda

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@dodalegal.ng
EMAIL_REPLY_TO=dodalegalpractitioners@gmail.com

# ── Payments (Paystack) ────────────────────────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# ── Admin Contact ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=dodalegalpractitioners@gmail.com

# ── Error Tracking (Sentry) ────────────────────────────────────────────────────
# Get from: sentry.io → Your Project → Settings → Client Keys
SENTRY_DSN=https://xxxx@oxxxxx.ingest.sentry.io/xxxxx
